//+------------------------------------------------------------------+\n//|                                        ZigZagPendingOrderEA.mq5 |\n//|                                   Copyright 2025, 1bzY2002      |\n//|                                             https://www.mql5.com |\n//+------------------------------------------------------------------+\n#property copyright "Copyright 2025, 1bzY2002"\n#property link      "https://www.mql5.com"\n#property version   "1.00"\n#property description "EA that places pending orders when ZigZag first paints - Continuation Strategy"\n\n#include <Trade\Trade.mqh>\n\n//--- Input Parameters\ninput group "=== ZigZag Settings ==="\ninput int InpDepth     = 12;   // ZigZag Depth\ninput int InpDeviation = 5;    // ZigZag Deviation  \ninput int InpBackstep  = 3;    // ZigZag Backstep\n\ninput group "=== Trading Settings ==="\ninput double InpLotSize        = 0.1;   // Lot Size\ninput int    InpOrderDistance  = 50;    // Pending Order Distance (pips)\ninput int    InpStopLoss       = 50;    // Stop Loss (pips)\ninput int    InpTakeProfit     = 50;    // Take Profit (pips)\ninput int    InpMagicNumber    = 12345; // Magic Number\n\ninput group "=== Risk Management ==="\ninput int    InpMaxOrders      = 1;     // Maximum Pending Orders\ninput bool   InpTradeOnNewBar  = true;  // Only Trade on New Bar\n\n//--- Global Variables\nCTrade trade;\nint zigzag_handle;\ndouble zigzag_buffer[];\ndatetime last_signal_time = 0;\nulong current_pending_ticket = 0;\nbool new_bar_flag = false;\n\n//--- ZigZag calculation variables (embedded)\ndouble HighMapBuffer[];\ndouble LowMapBuffer[];\nint ExtRecalc = 3;\n\nenum EnSearchMode\n{\n   Extremum = 0,  // searching for the first extremum\n   Peak = 1,      // searching for the next ZigZag peak\n   Bottom = -1    // searching for the next ZigZag bottom\n}\n\n//+------------------------------------------------------------------+\n//| Expert initialization function                                   |\n//+------------------------------------------------------------------+\nint OnInit()\n{\n   // Initialize trade object\n   trade.SetExpertMagicNumber(InpMagicNumber);\n   trade.SetTypeFillingBySymbol(_Symbol);\n   trade.SetDeviationInPoints(10);\n   \n   // Initialize arrays\n   ArraySetAsSeries(zigzag_buffer, true);\n   ArraySetAsSeries(HighMapBuffer, true);\n   ArraySetAsSeries(LowMapBuffer, true);\n   \n   ArrayResize(zigzag_buffer, 1000);\n   ArrayResize(HighMapBuffer, 1000);\n   ArrayResize(LowMapBuffer, 1000);\n   \n   // Initialize arrays\n   ArrayInitialize(zigzag_buffer, 0.0);\n   ArrayInitialize(HighMapBuffer, 0.0);\n   ArrayInitialize(LowMapBuffer, 0.0);\n   \n   Print("ZigZag Pending Order EA initialized successfully");\n   return(INIT_SUCCEEDED);\n}\n\n//+------------------------------------------------------------------+\n//| Expert deinitialization function                               |\n//+------------------------------------------------------------------+\nvoid OnDeinit(const int reason)\n{\n   Print("ZigZag Pending Order EA deinitialized. Reason: ", reason);\n}\n\n//+------------------------------------------------------------------+\n//| Expert tick function                                           |\n//+------------------------------------------------------------------+\nvoid OnTick()\n{\n   // Check for new bar\n   if(InpTradeOnNewBar && !IsNewBar())\n      return;\n      \n   // Calculate ZigZag\n   CalculateZigZag();\n   \n   // Check for new ZigZag signal\n   CheckForNewSignal();\n}\n\n//+------------------------------------------------------------------+\n//| Check if new bar formed                                        |\n//+------------------------------------------------------------------+\nbool IsNewBar()\n{\n   static datetime last_time = 0;\n   datetime current_time = iTime(_Symbol, PERIOD_CURRENT, 0);\n   \n   if(current_time != last_time)\n   {\n      last_time = current_time;\n      new_bar_flag = true;\n      return true;\n   }\n   return false;\n}\n\n//+------------------------------------------------------------------+\n//| Calculate ZigZag (embedded calculation)                        |\n//+------------------------------------------------------------------+\nvoid CalculateZigZag()\n{\n   int rates_total = Bars(_Symbol, PERIOD_CURRENT);\n   if(rates_total < 100) return;\n   \n   MqlRates rates[];\n   int copied = CopyRates(_Symbol, PERIOD_CURRENT, 0, rates_total, rates);\n   if(copied <= 0) return;\n   \n   ArraySetAsSeries(rates, true);\n   \n   // Prepare arrays for calculation\n   double high[], low[], close[];\n   ArrayResize(high, rates_total);\n   ArrayResize(low, rates_total);\n   ArrayResize(close, rates_total);\n   ArraySetAsSeries(high, true);\n   ArraySetAsSeries(low, true);\n   ArraySetAsSeries(close, true);\n   \n   for(int i = 0; i < rates_total; i++)\n   {\n      high[i] = rates[i].high;\n      low[i] = rates[i].low;\n      close[i] = rates[i].close;\n   }\n   \n   // ZigZag calculation logic (simplified)\n   int start = InpDepth;\n   int shift = 0, back = 0;\n   double val = 0, res = 0;\n   double last_high = 0, last_low = 0;\n   \n   // Clear buffers\n   ArrayInitialize(zigzag_buffer, 0.0);\n   ArrayInitialize(HighMapBuffer, 0.0);\n   ArrayInitialize(LowMapBuffer, 0.0);\n   \n   // Find extremes\n   for(shift = start; shift < rates_total - 1; shift++)\n   {\n      // Low extremes\n      val = low[ArrayMinimum(low, shift, InpDepth)];\n      if(val != last_low)\n      {\n         last_low = val;\n         if((low[shift] - val) <= InpDeviation * _Point)\n         {\n            for(back = 1; back <= InpBackstep; back++)\n            {\n               if(shift - back >= 0)\n               {\n                  res = LowMapBuffer[shift - back];\n                  if((res != 0) && (res > val))\n                     LowMapBuffer[shift - back] = 0.0;\n               }\n            }\n            if(low[shift] == val)\n               LowMapBuffer[shift] = val;\n         }\n      }\n      \n      // High extremes  \n      val = high[ArrayMaximum(high, shift, InpDepth)];\n      if(val != last_high)\n      {\n         last_high = val;\n         if((val - high[shift]) <= InpDeviation * _Point)\n         {\n            for(back = 1; back <= InpBackstep; back++)\n            {\n               if(shift - back >= 0)\n               {\n                  res = HighMapBuffer[shift - back];\n                  if((res != 0) && (res < val))\n                     HighMapBuffer[shift - back] = 0.0;\n               }\n            }\n            if(high[shift] == val)\n               HighMapBuffer[shift] = val;\n         }\n      }\n   }\n   \n   // Create ZigZag line\n   int extreme_search = Extremum;\n   double last_extreme_high = 0, last_extreme_low = 0;\n   int last_high_pos = 0, last_low_pos = 0;\n   \n   for(shift = start; shift < rates_total - 1; shift++)\n   {\n      switch(extreme_search)\n      {\n         case Extremum:\n            if(HighMapBuffer[shift] != 0)\n            {\n               last_extreme_high = HighMapBuffer[shift];\n               last_high_pos = shift;\n               extreme_search = Bottom;\n               zigzag_buffer[shift] = last_extreme_high;\n            }\n            if(LowMapBuffer[shift] != 0)\n            {\n               last_extreme_low = LowMapBuffer[shift];\n               last_low_pos = shift;\n               extreme_search = Peak;\n               zigzag_buffer[shift] = last_extreme_low;\n            }\n            break;\n            \n         case Peak:\n            if(LowMapBuffer[shift] != 0 && LowMapBuffer[shift] < last_extreme_low)\n            {\n               zigzag_buffer[last_low_pos] = 0.0;\n               last_low_pos = shift;\n               last_extreme_low = LowMapBuffer[shift];\n               zigzag_buffer[shift] = last_extreme_low;\n            }\n            if(HighMapBuffer[shift] != 0)\n            {\n               last_extreme_high = HighMapBuffer[shift];\n               last_high_pos = shift;\n               zigzag_buffer[shift] = last_extreme_high;\n               extreme_search = Bottom;\n            }\n            break;\n            \n         case Bottom:\n            if(HighMapBuffer[shift] != 0 && HighMapBuffer[shift] > last_extreme_high)\n            {\n               zigzag_buffer[last_high_pos] = 0.0;\n               last_high_pos = shift;\n               last_extreme_high = HighMapBuffer[shift];\n               zigzag_buffer[shift] = last_extreme_high;\n            }\n            if(LowMapBuffer[shift] != 0)\n            {\n               last_extreme_low = LowMapBuffer[shift];\n               last_low_pos = shift;\n               zigzag_buffer[shift] = last_extreme_low;\n               extreme_search = Peak;\n            }\n            break;\n      }\n   }\n}\n\n//+------------------------------------------------------------------+\n//| Check for new ZigZag signal                                    |\n//+------------------------------------------------------------------+\nvoid CheckForNewSignal()\n{\n   datetime current_time = iTime(_Symbol, PERIOD_CURRENT, 0);\n   \n   // Check if we have a new ZigZag point on current or previous bar\n   for(int i = 0; i <= 2; i++)\n   {\n      if(zigzag_buffer[i] != 0.0)\n      {\n         datetime signal_time = iTime(_Symbol, PERIOD_CURRENT, i);\n         \n         // Skip if we already processed this signal\n         if(signal_time <= last_signal_time)\n            continue;\n            \n         // Cancel existing pending orders\n         CancelPendingOrders();\n         \n         // Determine signal type and place order\n         bool is_high = (zigzag_buffer[i] >= iHigh(_Symbol, PERIOD_CURRENT, i));\n         PlacePendingOrder(is_high, zigzag_buffer[i], signal_time);\n         \n         last_signal_time = signal_time;\n         break;\n      }\n   }\n}\n\n//+------------------------------------------------------------------+\n//| Place pending order based on ZigZag signal                     |\n//+------------------------------------------------------------------+\nvoid PlacePendingOrder(bool is_high_signal, double signal_price, datetime signal_time)\n{\n   double current_bid = SymbolInfoDouble(_Symbol, SYMBOL_BID);\n   double current_ask = SymbolInfoDouble(_Symbol, SYMBOL_ASK);\n   double point = SymbolInfoDouble(_Symbol, SYMBOL_POINT);\n   int digits = (int)SymbolInfoInteger(_Symbol, SYMBOL_DIGITS);\n   \n   double order_price, sl_price, tp_price;\n   ENUM_ORDER_TYPE order_type;\n   \n   if(is_high_signal) // ZigZag High = Continuation Up = Buy Stop\n   {\n      order_type = ORDER_TYPE_BUY_STOP;\n      order_price = NormalizeDouble(signal_price + (InpOrderDistance * point), digits);\n      sl_price = NormalizeDouble(order_price - (InpStopLoss * point), digits);\n      tp_price = NormalizeDouble(order_price + (InpTakeProfit * point), digits);\n      \n      // Ensure order price is above current ask\n      if(order_price <= current_ask)\n         order_price = NormalizeDouble(current_ask + (InpOrderDistance * point), digits);\n   }\n   else // ZigZag Low = Continuation Down = Sell Stop  \n   {\n      order_type = ORDER_TYPE_SELL_STOP;\n      order_price = NormalizeDouble(signal_price - (InpOrderDistance * point), digits);\n      sl_price = NormalizeDouble(order_price + (InpStopLoss * point), digits);\n      tp_price = NormalizeDouble(order_price - (InpTakeProfit * point), digits);\n      \n      // Ensure order price is below current bid\n      if(order_price >= current_bid)\n         order_price = NormalizeDouble(current_bid - (InpOrderDistance * point), digits);\n   }\n   \n   // Place the pending order\n   if(trade.OrderOpen(_Symbol, order_type, InpLotSize, 0, order_price, sl_price, tp_price, \n                      ORDER_TIME_GTC, 0, "ZZ_Pending_" + IntegerToString(signal_time)))\n   {\n      current_pending_ticket = trade.ResultOrder();\n      string order_type_str = (order_type == ORDER_TYPE_BUY_STOP) ? "BUY STOP" : "SELL STOP";\n      Print("✓ Placed ", order_type_str, " order #", current_pending_ticket, \n            " at ", order_price, " | SL: ", sl_price, " | TP: ", tp_price);\n   }\n   else\n   {\n      Print("✗ Failed to place pending order. Error: ", trade.ResultRetcode(), " - ", trade.ResultRetcodeDescription());\n   }\n}\n\n//+------------------------------------------------------------------+\n//| Cancel all pending orders with our magic number                |\n//+------------------------------------------------------------------+\nvoid CancelPendingOrders()\n{\n   for(int i = OrdersTotal() - 1; i >= 0; i--)\n   {\n      ulong ticket = OrderGetTicket(i);\n      if(ticket > 0 && OrderGetInteger(ORDER_MAGIC) == InpMagicNumber)\n      {\n         if(trade.OrderDelete(ticket))\n         {\n            Print("✓ Cancelled pending order #", ticket);\n         }\n      }\n   }\n}